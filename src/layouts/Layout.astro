---
import Analytics from '@vercel/analytics/astro';
import { APP_VERSION, GITHUB_URL } from '../consts';

interface Props {
  title?: string;
  description?: string;
}
const {
  title = 'inkwell — Write without distraction.',
  description = 'A local-first markdown editor for macOS, Windows, and Linux. Your notes stay as plain .md files — private, portable, and completely under your control.',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageURL = new URL('/og-image.png', Astro.site);

const softwareApplicationSchema = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'inkwell',
  description,
  url: 'https://inkwell-lp.vercel.app/',
  operatingSystem: ['macOS', 'Windows', 'Linux'],
  applicationCategory: 'DeveloperApplication',
  softwareVersion: APP_VERSION,
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'USD',
  },
  downloadUrl: `${GITHUB_URL}/releases/latest`,
};
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="inkwell — Write without distraction." />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/inkwell-icon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" sizes="any" />
    <link rel="apple-touch-icon" href="/inkwell-icon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&display=swap" rel="stylesheet" />
    <script type="application/ld+json" set:html={JSON.stringify(softwareApplicationSchema)} />
  </head>
  <body>
    <slot />
    <Analytics />
  </body>
</html>

<style is:global>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg:           #1C1A17;
    --bg-raised:    #212018;
    --bg-card:      #252219;
    --bg-subtle:    #2D2A22;
    --border:       rgba(255, 255, 255, 0.07);
    --border-mid:   rgba(255, 255, 255, 0.11);
    --accent:       #C4832A;
    --accent-light: #D49840;
    --accent-dim:   rgba(196, 131, 42, 0.15);
    --accent-glow:  rgba(196, 131, 42, 0.07);
    --text:         #F0EDE8;
    --text-2:       #9A8E7E;
    --text-3:       #9A8B79;
    --nav-bg:       rgba(28, 26, 23, 0.88);
    --radius:       10px;
    --radius-lg:    16px;
    --radius-xl:    22px;
  }

  html { scroll-behavior: smooth; }

  body {
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
    background: var(--bg);
    color: var(--text);
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    line-height: 1.6;
    overflow-x: hidden;
  }

  ::selection { background: var(--accent-dim); color: var(--text); }

  ::-webkit-scrollbar { width: 5px; }
  ::-webkit-scrollbar-track { background: transparent; }
  ::-webkit-scrollbar-thumb { background: #3A362C; border-radius: 3px; }

  a { color: inherit; text-decoration: none; }

  img, svg { display: block; }
</style>
