<script define:vars={{ themePalettes }}>
  function applyTheme(name) {
    const palette = themePalettes[name];
    if (!palette) return;
    const root = document.documentElement;
    for (const [key, val] of Object.entries(palette)) {
      root.style.setProperty(key, val);
    }
    // Update active swatch ring
    document.querySelectorAll(".theme-swatch").forEach((swatch) => {
      const isActive = swatch.dataset.theme === name;
      swatch.classList.toggle("active", isActive);
      if (isActive) {
        swatch.style.borderColor = palette["--accent"];
        swatch.style.boxShadow = `0 0 0 3px ${palette["--accent"]}33, 0 16px 40px rgba(0,0,0,0.4)`;
      } else {
        swatch.style.borderColor = "transparent";
        swatch.style.boxShadow = "";
      }
    });
  }

  document.querySelectorAll(".theme-swatch").forEach((swatch) => {
    swatch.setAttribute("tabindex", "0");
    swatch.setAttribute("role", "button");
    swatch.setAttribute("aria-label", `Apply ${swatch.dataset.theme} theme`);
    swatch.addEventListener("click", () => applyTheme(swatch.dataset.theme));
    swatch.addEventListener("keydown", (e) => {
      if (e.key === "Enter" || e.key === " ") {
        e.preventDefault();
        applyTheme(swatch.dataset.theme);
      }
    });
  });

  // Boot with Midnight active
  applyTheme("Midnight");

  // ── OS detection: highlight & scale the matching download button ──────────
  (function () {
    const ua = navigator.userAgent;
    let os = "mac";
    if (/windows/i.test(ua))      os = "win";
    else if (/linux/i.test(ua))   os = "linux";
    else if (/mac/i.test(ua))     os = "mac";

    // Activate matching buttons in every dl-row on the page
    document.querySelectorAll(`.dl-btn[data-os="${os}"]`).forEach(el => {
      el.classList.add("dl-active");
    });

    // Wire the nav Download button to the correct platform URL
    const DL_URLS = {
      mac:   document.querySelector('#hero-dl-mac')?.href,
      win:   document.querySelector('#hero-dl-win')?.href,
      linux: document.querySelector('#hero-dl-linux')?.href,
    };
    const navBtn = document.getElementById('nav-dl-btn');
    if (navBtn && DL_URLS[os]) navBtn.href = DL_URLS[os];
  })();
</script>
