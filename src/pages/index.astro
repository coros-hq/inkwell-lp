    background: var(--bg-subtle);
    border: 1px solid var(--border-mid);
    border-radius: 4px;
    padding: 1px 5px;
    color: var(--text);
  }
  .detail-item code {
    font-family: "SF Mono", monospace;
    font-size: 12px;
    color: var(--accent-light);
