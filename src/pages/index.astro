                  <div
                    class="swatch-line"
                    style={`background:${t.light ? "rgba(0,0,0,0.1)" : "rgba(255,255,255,0.1)"};width:80%`}
                  />
                  <div
                    class="swatch-line"
                    style={`background:${t.light ? "rgba(0,0,0,0.1)" : "rgba(255,255,255,0.1)"};width:50%`}
