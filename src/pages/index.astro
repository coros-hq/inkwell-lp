                <span class="planner-day-num">2</span>
              </div>
              <div class="planner-day">
                <span class="planner-day-label">FRI</span>
                <span class="planner-day-num">3</span>
              </div>
              <div class="planner-day planner-day--dim">
                <span class="planner-day-label">SAT</span>
                <span class="planner-day-num">4</span>
              </div>
              <div class="planner-day planner-day--dim">
                <span class="planner-day-label">SUN</span>
                <span class="planner-day-num">5</span>
              </div>
            </div>
            <button class="planner-nav">›</button>
          </div>
        </div>

        <!-- Task list -->
        <div class="planner-body">
          <div class="planner-tag-group">
            <span class="planner-tag-label">MARKETING</span>
            <div class="planner-task planner-task--done">
              <span class="planner-checkbox planner-checkbox--checked">
                <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              </span>
              <span class="planner-task-text">Publish the blog post</span>
            </div>
            <div class="planner-task">
              <span class="planner-checkbox"></span>
              <span class="planner-task-text">Draft Q3 campaign brief</span>
            </div>
          </div>
          <div class="planner-tag-group">
            <span class="planner-tag-label">ENGINEERING</span>
            <div class="planner-task planner-task--done">
              <span class="planner-checkbox planner-checkbox--checked">
                <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              </span>
              <span class="planner-task-text">Review open PRs</span>
            </div>
            <div class="planner-task">
              <span class="planner-checkbox"></span>
              <span class="planner-task-text">Write release notes</span>
