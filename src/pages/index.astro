  /* ── Footer ───────────────────────────────────────────────── */
  footer {
    border-top: 1px solid var(--border);
    padding: 28px 32px;
  }
  .footer-inner {
    max-width: 1080px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    gap: 20px;
  }
  .footer-brand {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 14px;
    font-weight: 500;
    color: var(--text-2);
    flex-shrink: 0;
  }
  .footer-brand img {
    border-radius: 5px;
  }
  .footer-copy {
    flex: 1;
    font-size: 13px;
    color: var(--text-3);
  }
  .footer-gh {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 13px;
    color: var(--text-2);
    transition: color 0.15s;
    flex-shrink: 0;
  }
  .footer-gh:hover {
    color: var(--text);
  }
  .footer-docs {
    font-size: 13px;
    color: var(--text-2);
    transition: color 0.15s;
    flex-shrink: 0;
    margin-right: 8px;
  }
  .footer-docs:hover {
    color: var(--text);
  }

  /* ── Global theme transitions ─────────────────────────────── */
  *,
  *::before,
  *::after {
    transition:
      background-color 0.35s ease,
      border-color 0.35s ease,
      color 0.25s ease,
      box-shadow 0.35s ease,
      fill 0.25s ease;
  }
  /* Don't transition layout or transform globally */
  a,
  button,
  .theme-swatch,
  .feature-card,
  .detail-item {
    transition:
      background-color 0.35s ease,
      border-color 0.35s ease,
      color 0.25s ease,
      box-shadow 0.35s ease,
      transform 0.2s ease;
  }

  /* ── Responsive ───────────────────────────────────────────── */
  @media (max-width: 900px) {
    .hero-inner {
      grid-template-columns: 1fr;
    }
    .app-window {
      display: none;
    }
    .features-grid {
      grid-template-columns: 1fr;
    }
    .feature-card {
      border-radius: var(--radius) !important;
    }
    .themes-grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .details-grid {
      grid-template-columns: 1fr;
    }
  }
  @media (max-width: 600px) {
    .nav-links {
      display: none;
    }
    .themes-grid {
      grid-template-columns: repeat(2, 1fr);
    }
    h1 {
      font-size: 36px;
    }
    .features,
    .themes-section,
    .details {
