---
import Layout from "../layouts/Layout.astro";
import { APP_VERSION, GITHUB_URL } from "../consts";

const VERSION = APP_VERSION;
// Linked via GitHub's stable /latest/download/ redirect rather than a pinned
// v{VERSION} tag path — the project's release tags and its Tauri-embedded
// version string have drifted before (e.g. tag v0.7.7 shipping binaries
// still named inkwell_0.7.4_*), so pinning to a tag risks a 404.
const DL_MAC   = `https://github.com/coros-hq/inkwell/releases/latest/download/inkwell_${VERSION}_universal.dmg`;
const DL_WIN   = `https://github.com/coros-hq/inkwell/releases/latest/download/inkwell_${VERSION}_x64-setup.exe`;
const DL_LINUX = `https://github.com/coros-hq/inkwell/releases/latest/download/inkwell_${VERSION}_amd64.deb`;

const features = [
  {
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18M3 12h18M3 18h18"/><path d="M8 6V4m0 16v-2M16 6V4m0 16v-2"/></svg>`,
    title: "Yours, always",
    body: "Notes are stored as plain <code>.md</code> files in a vault folder you choose — real directories, real files, YAML frontmatter. Open them in any editor, back them up anywhere.",
  },
  {
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="9" height="18" rx="1"/><rect x="13" y="3" width="9" height="18" rx="1"/></svg>`,
    title: "Write and see at once",
    body: "A split view shows your Markdown rendered live as you type. Or collapse to a full-screen editor when you need to focus on the words alone.",
  },
  {
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"/></svg>`,
    title: "Eight themes",
    body: "Midnight, Parchment, Ink, Dusk, Forest, Sepia, Gruvbox, Fog — each one tuned for long writing sessions. Build your own with the custom theme editor.",
  },
  {
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 5H7a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-2"/><rect x="9" y="3" width="6" height="4" rx="1"/><path d="M9 12h6M9 16h4"/></svg>`,
    title: "Built for more",
    body: "Kanban boards, linked notes, file attachments, ⌘K search, and export to Markdown, HTML, or PDF — without leaving the app.",
  },
  {
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2C6.48 2 2 6.48 2 12c0 4.42 2.87 8.17 6.84 9.49.5.09.66-.22.66-.48v-1.7C6.73 19.91 6.14 18 6.14 18c-.46-1.16-1.11-1.47-1.11-1.47-.91-.62.07-.61.07-.61 1 .07 1.53 1.03 1.53 1.03.89 1.52 2.34 1.08 2.91.83.09-.65.35-1.08.63-1.33-2.22-.25-4.55-1.11-4.55-4.94 0-1.09.39-1.98 1.03-2.68-.1-.25-.45-1.27.1-2.64 0 0 .84-.27 2.75 1.02A9.58 9.58 0 0 1 12 6.8c.85 0 1.71.11 2.51.33 1.91-1.29 2.75-1.02 2.75-1.02.55 1.37.2 2.39.1 2.64.64.7 1.03 1.59 1.03 2.68 0 3.84-2.34 4.68-4.57 4.93.36.31.68.92.68 1.85v2.75c0 .27.16.58.67.48A10.01 10.01 0 0 0 22 12c0-5.52-4.48-10-10-10z"/></svg>`,
    title: "GitHub sync",
    body: "Push any note to a GitHub repository as a <code>.md</code> file, or pull the latest version back in. Keep your project docs and READMEs in sync from inside inkwell.",
  },
  {
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a10 10 0 1 0 0 20 10 10 0 0 0 0-20z"/><path d="M12 8v4l3 3"/><path d="M8 3.5A9.96 9.96 0 0 1 12 2"/></svg>`,
    title: "Claude MCP",
    body: "A native MCP server lets Claude read, search, and write to your vault directly. Ask Claude to summarise your notes, draft new ones, or find anything — it talks to inkwell natively.",
  },
  {
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>`,
    title: "Abbreviations",
    body: "Type <code>:today</code> for today's date, <code>:now</code> for the time, or define your own text snippets. The trigger character is configurable in Settings.",
  },
  {
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M16 8v5a3 3 0 0 0 6 0v-1a10 10 0 1 0-3.92 7.94"/></svg>`,
    title: "Link notes with @",
    body: "Type <code>@</code> and start typing a title to search your vault and drop in a link to another note — no copy-pasting, no leaving the keyboard.",
  },
];

const themes = [
  { name: "Midnight", bg: "#1C1A17", accent: "#C4832A", light: false },
  { name: "Parchment", bg: "#F5F2EC", accent: "#9A5E22", light: true },
  { name: "Ink", bg: "#0E1018", accent: "#5599E8", light: false },
  { name: "Dusk", bg: "#0E0C17", accent: "#A866E8", light: false },
  { name: "Forest", bg: "#0B1410", accent: "#42C870", light: false },
  { name: "Sepia", bg: "#EFE8D8", accent: "#8A3818", light: true },
  { name: "Gruvbox", bg: "#282828", accent: "#D79921", light: false },
  { name: "Fog", bg: "#F4F6FA", accent: "#3A6ACC", light: true },
];

// Full palette per theme — used by client-side JS
const themePalettes = {
  Midnight: {
    "--bg": "#1C1A17",
    "--bg-raised": "#212018",
    "--bg-card": "#252219",
    "--bg-subtle": "#2D2A22",
    "--border": "rgba(255,255,255,0.07)",
    "--border-mid": "rgba(255,255,255,0.11)",
    "--accent": "#C4832A",
    "--accent-light": "#D49840",
    "--accent-dim": "rgba(196,131,42,0.15)",
    "--text": "#F0EDE8",
    "--text-2": "#9A8E7E",
    "--text-3": "#5A5044",
    "--nav-bg": "rgba(28,26,23,0.88)",
  },
  Parchment: {
    "--bg": "#F5F2EC",
    "--bg-raised": "#F0EDE5",
    "--bg-card": "#EDE9E1",
    "--bg-subtle": "#E5E0D5",
    "--border": "rgba(0,0,0,0.08)",
    "--border-mid": "rgba(0,0,0,0.14)",
    "--accent": "#9A5E22",
    "--accent-light": "#B06E28",
    "--accent-dim": "rgba(154,94,34,0.12)",
    "--text": "#2A2015",
    "--text-2": "#6A5A42",
    "--text-3": "#A89878",
    "--nav-bg": "rgba(245,242,236,0.9)",
  },
  Ink: {
    "--bg": "#0E1018",
    "--bg-raised": "#131621",
    "--bg-card": "#171B26",
    "--bg-subtle": "#1E2333",
    "--border": "rgba(255,255,255,0.07)",
    "--border-mid": "rgba(255,255,255,0.11)",
    "--accent": "#5599E8",
    "--accent-light": "#70AAEF",
    "--accent-dim": "rgba(85,153,232,0.15)",
    "--text": "#E8EDF5",
    "--text-2": "#8892A8",
    "--text-3": "#505870",
    "--nav-bg": "rgba(14,16,24,0.9)",
  },
  Dusk: {
    "--bg": "#0E0C17",
    "--bg-raised": "#130F1E",
    "--bg-card": "#181224",
    "--bg-subtle": "#1F1830",
    "--border": "rgba(255,255,255,0.07)",
    "--border-mid": "rgba(255,255,255,0.11)",
    "--accent": "#A866E8",
    "--accent-light": "#BA80F0",
    "--accent-dim": "rgba(168,102,232,0.15)",
    "--text": "#EDE8F5",
    "--text-2": "#8878A8",
    "--text-3": "#504868",
    "--nav-bg": "rgba(14,12,23,0.9)",
  },
  Forest: {
    "--bg": "#0B1410",
    "--bg-raised": "#0F1A14",
    "--bg-card": "#121F17",
    "--bg-subtle": "#172A1E",
    "--border": "rgba(255,255,255,0.07)",
    "--border-mid": "rgba(255,255,255,0.11)",
    "--accent": "#42C870",
    "--accent-light": "#58D882",
    "--accent-dim": "rgba(66,200,112,0.15)",
    "--text": "#E8F5EE",
    "--text-2": "#7A9E88",
    "--text-3": "#446854",
    "--nav-bg": "rgba(11,20,16,0.9)",
  },
  Sepia: {
    "--bg": "#EFE8D8",
    "--bg-raised": "#EAE2D0",
    "--bg-card": "#E4DBC8",
    "--bg-subtle": "#DAD0BC",
    "--border": "rgba(0,0,0,0.08)",
    "--border-mid": "rgba(0,0,0,0.14)",
    "--accent": "#8A3818",
    "--accent-light": "#A04520",
    "--accent-dim": "rgba(138,56,24,0.12)",
    "--text": "#2A1A0E",
    "--text-2": "#6A4A32",
    "--text-3": "#A8886E",
    "--nav-bg": "rgba(239,232,216,0.9)",
  },
  Gruvbox: {
    "--bg": "#282828",
    "--bg-raised": "#2E2E2E",
    "--bg-card": "#333333",
    "--bg-subtle": "#3A3A3A",
    "--border": "rgba(255,255,255,0.08)",
    "--border-mid": "rgba(255,255,255,0.14)",
    "--accent": "#D79921",
    "--accent-light": "#E8AE30",
    "--accent-dim": "rgba(215,153,33,0.15)",
    "--text": "#EBDBB2",
    "--text-2": "#A89880",
    "--text-3": "#686858",
    "--nav-bg": "rgba(40,40,40,0.9)",
  },
  Fog: {
    "--bg": "#F4F6FA",
    "--bg-raised": "#EFF2F8",
    "--bg-card": "#E8EDF5",
    "--bg-subtle": "#DDE4EF",
    "--border": "rgba(0,0,0,0.07)",
    "--border-mid": "rgba(0,0,0,0.12)",
    "--accent": "#3A6ACC",
    "--accent-light": "#4A7ADE",
    "--accent-dim": "rgba(58,106,204,0.12)",
    "--text": "#1A2035",
    "--text-2": "#5A6888",
    "--text-3": "#9AA8C8",
    "--nav-bg": "rgba(244,246,250,0.9)",
  },
};
---

<Layout>
  <!-- ── Nav ───────────────────────────────────────────────── -->
  <nav>
    <div class="nav-inner">
      <a href="/" class="wordmark">
        <img src="/inkwell-icon.svg" alt="inkwell" width="26" height="26" />
        inkwell
      </a>
      <div class="nav-links">
        <a href="#features">Features</a>
        <a href="#canvas">Canvas</a>
        <a href="#themes">Themes</a>
        <a href={GITHUB_URL} target="_blank" rel="noopener">GitHub</a>
        <a href="/docs">Docs</a>
      </div>
      <a href={DL_MAC} class="btn-nav" id="nav-dl-btn">
        Download
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M5 12l7 7 7-7"></path></svg>
      </a>
    </div>
  </nav>

  <main>
  <!-- ── Hero ─────────────────────────────────────────────── -->
  <section class="hero">
    <div class="hero-glow" aria-hidden="true"></div>

    <div class="hero-inner">
      <div class="hero-text">
        <div class="badge">
          <span class="badge-dot"></span>
          macOS · Windows · Linux &nbsp;·&nbsp; Free &nbsp;·&nbsp; Open Source
        </div>

        <h1>Write without<br />distraction.</h1>

        <p class="hero-sub">
          A local-first markdown editor for every platform. Your notes stay as
          plain&nbsp;<code>.md</code>&nbsp;files — private, portable, entirely
          yours.
        </p>

        <div class="hero-ctas">
          <div class="dl-row" id="hero-dl">
            <a href={DL_MAC}   class="dl-btn" data-os="mac"   id="hero-dl-mac">
              <span class="dl-icon"><svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg"><path d="M12.152 6.896c-.948 0-2.415-1.078-3.96-1.04-2.04.027-3.91 1.183-4.961 3.014-2.117 3.675-.546 9.103 1.519 12.09 1.013 1.454 2.208 3.09 3.792 3.039 1.52-.065 2.09-.987 3.935-.987 1.831 0 2.35.987 3.96.948 1.637-.026 2.676-1.48 3.676-2.948 1.156-1.688 1.636-3.325 1.662-3.415-.039-.013-3.182-1.221-3.22-4.857-.026-3.04 2.48-4.494 2.597-4.559-1.429-2.09-3.623-2.324-4.39-2.376-2-.156-3.675 1.09-4.61 1.09zM15.53 3.83c.843-1.012 1.4-2.427 1.245-3.83-1.207.052-2.662.805-3.532 1.818-.78.896-1.454 2.338-1.273 3.714 1.338.104 2.715-.688 3.559-1.701"/></svg></span>
              <span class="dl-label">macOS</span>
              <span class="dl-sub">.dmg · Universal</span>
            </a>
            <a href={DL_WIN}   class="dl-btn" data-os="win"   id="hero-dl-win">
              <span class="dl-icon"><svg width="15" height="15" viewBox="0 0 88 88" fill="currentColor" xmlns="http://www.w3.org/2000/svg"><path d="M0 12.402l35.687-4.86.016 34.423-35.67.203zm35.67 33.529l.028 34.453L.028 75.48.026 45.7zm4.326-39.025L87.314 0v41.527l-47.318.376zm47.329 39.349l-.011 41.34-47.318-6.678-.066-34.739z"/></svg></span>
              <span class="dl-label">Windows</span>
              <span class="dl-sub">.exe · x64</span>
            </a>
            <a href={DL_LINUX} class="dl-btn" data-os="linux" id="hero-dl-linux">
              <span class="dl-icon"><svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg"><path d="M20 3H4c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm0 16H4V7h16v12zM6.41 8.59L5 10l4 4-4 4 1.41 1.41L11.83 14 6.41 8.59zM12 17h7v-2h-7v2z"/></svg></span>
              <span class="dl-label">Linux</span>
              <span class="dl-sub">.deb · amd64</span>
            </a>
          </div>
          <a href={GITHUB_URL} class="btn-ghost dl-github" target="_blank" rel="noopener">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg"><path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/></svg>
            GitHub
          </a>
        </div>

        <p class="version-note">v{VERSION} · Free · Open Source</p>
      </div>

      <!-- App window mockup -->
      <div class="app-window" aria-hidden="true">
        <div class="titlebar">
          <span class="dot dot-red"></span>
          <span class="dot dot-yellow"></span>
          <span class="dot dot-green"></span>
          <span class="window-title">inkwell</span>
        </div>
        <div class="app-body">
          <!-- Sidebar -->
          <div class="mock-sidebar">
            <div class="mock-search">
              <span class="mock-search-icon">⌘</span>
              <span class="mock-search-placeholder">Search</span>
            </div>
            <div class="mock-section-label">LIBRARY</div>
            <div class="mock-folder expanded">
              <span class="mock-folder-icon">▾</span> Writing
            </div>
            <div class="mock-note active">The Daily Note</div>
            <div class="mock-note">Ideas</div>
            <div class="mock-note">Drafts</div>
            <div class="mock-folder">
              <span class="mock-folder-icon">▸</span> Projects
            </div>
          </div>
          <!-- Editor -->
          <div class="mock-editor">
            <div class="mock-line mock-h1">The Daily Note</div>
            <div class="mock-line mock-gap"></div>
            <div class="mock-line mock-text">
              Sometimes the best ideas come when you
            </div>
            <div class="mock-line mock-text">
              stop trying to have them. Open a blank
            </div>
            <div class="mock-line mock-text">
              page and just start&nbsp;<span class="mock-bold">writing.</span>
            </div>
            <div class="mock-line mock-gap"></div>
            <div class="mock-line mock-h2">## Notes for today</div>
            <div class="mock-line mock-gap"></div>
            <div class="mock-line mock-list">- [x] Review morning notes</div>
            <div class="mock-line mock-list">- [ ] Write the draft</div>
            <div class="mock-line mock-list">- [ ] Publish the post</div>
            <div class="mock-line mock-gap"></div>
            <div class="mock-line mock-code">```javascript</div>
            <div class="mock-line mock-code-inner">
              <span class="c-keyword">const</span> write = () <span
                class="c-keyword">=></span
              >
              <span class="c-string">'start here'</span>
            </div>
            <div class="mock-line mock-code">```</div>
            <div class="mock-cursor"></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Features ─────────────────────────────────────────── -->
  <section class="features" id="features">
    <div class="section-inner">
      <div class="section-label">Features</div>
      <h2>
        Everything you need.<br /><span class="muted">Nothing you don't.</span>
      </h2>

      <div class="features-grid">
        {
          features.map((f) => (
            <div class="feature-card">
              <div class="feature-icon" set:html={f.icon} />
              <h3>{f.title}</h3>
              <p set:html={f.body} />
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ── Canvas ───────────────────────────────────────────── -->
  <section class="canvas-section" id="canvas">
    <div class="section-inner">
      <div class="section-label">Canvas</div>
      <h2>
        Draw without<br /><span class="muted">switching apps.</span>
      </h2>
      <p class="section-sub">
        A full drawing canvas lives inside inkwell — flowcharts, mind maps, sequence diagrams, and freehand sketches, right next to your notes.
      </p>

      <!-- Canvas window mockup -->
      <div class="canvas-window">
        <div class="titlebar">
          <span class="dot dot-red"></span>
          <span class="dot dot-yellow"></span>
          <span class="dot dot-green"></span>
          <span class="window-title">inkwell — Canvas</span>
        </div>
        <div class="canvas-body">
          <!-- dot-grid background -->
          <svg class="canvas-dot-grid" aria-hidden="true">
            <defs>
              <pattern id="dot-pattern" x="0" y="0" width="28" height="28" patternUnits="userSpaceOnUse">
                <circle cx="1" cy="1" r="1" fill="rgba(255,255,255,0.08)" />
              </pattern>
            </defs>
            <rect width="100%" height="100%" fill="url(#dot-pattern)" />
          </svg>

          <!-- Canvas shapes: mini flowchart -->
          <svg class="canvas-shapes" viewBox="0 0 600 320" aria-hidden="true" fill="none">
            <defs>
              <marker id="arr" markerWidth="7" markerHeight="7" refX="5" refY="3" orient="auto">
                <path d="M0,0 L5,3 L0,6 Z" fill="rgba(248,250,252,0.7)" />
              </marker>
            </defs>

            <!-- Flowchart (left side) -->
            <ellipse cx="148" cy="50" rx="68" ry="28" stroke="rgba(248,250,252,0.75)" stroke-width="1.5" />
            <text x="148" y="55" text-anchor="middle" font-size="12" fill="rgba(248,250,252,0.8)" font-family="Inter,sans-serif" font-weight="600">Start</text>

            <line x1="148" y1="79" x2="148" y2="108" stroke="rgba(248,250,252,0.55)" stroke-width="1.5" marker-end="url(#arr)" />

            <rect x="70" y="110" width="156" height="48" rx="6" stroke="rgba(248,250,252,0.75)" stroke-width="1.5" />
            <text x="148" y="139" text-anchor="middle" font-size="11" fill="rgba(248,250,252,0.7)" font-family="Inter,sans-serif">Write the draft</text>

            <line x1="148" y1="159" x2="148" y2="188" stroke="rgba(248,250,252,0.55)" stroke-width="1.5" marker-end="url(#arr)" />

            <rect x="70" y="190" width="156" height="48" rx="6" stroke="rgba(248,250,252,0.75)" stroke-width="1.5" />
            <text x="148" y="219" text-anchor="middle" font-size="11" fill="rgba(248,250,252,0.7)" font-family="Inter,sans-serif">Review &amp; edit</text>

            <line x1="148" y1="239" x2="148" y2="268" stroke="rgba(248,250,252,0.55)" stroke-width="1.5" marker-end="url(#arr)" />

            <ellipse cx="148" cy="290" rx="68" ry="28" stroke="rgba(248,250,252,0.75)" stroke-width="1.5" />
