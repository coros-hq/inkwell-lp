  <section class="quicknote-section" id="quicknote">
    <div class="section-inner">
      <div class="section-label">Quick Capture</div>
      <h2>
        The thought won't wait.<br /><span class="muted">Neither should you.</span>
      </h2>
      <p class="section-sub">
        Press <kbd>⌘N</kbd> from anywhere — even when inkwell is closed — and a focused capture window appears. Write, pick a folder, save. It lands in your vault.
      </p>

      <div class="qn-window">
        <div class="titlebar">
          <span class="dot dot-red"></span>
          <span class="dot dot-yellow"></span>
          <span class="dot dot-green"></span>
          <div class="qn-folder-picker">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/></svg>
            <span>Marketing</span>
            <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
          </div>
          <button class="qn-close-btn" aria-label="Close">
            <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
          </button>
        </div>
        <div class="qn-body">
          <span class="qn-placeholder">Quick note... <span class="qn-placeholder-sub">(Markdown supported)</span></span>
          <div class="qn-cursor-blink"></div>
        </div>
        <div class="qn-footer">
          <span class="qn-hints">
            <kbd>⌘↵</kbd> to save · <kbd>Esc</kbd> to cancel · Markdown supported
          </span>
          <button class="qn-save-btn">Save</button>
        </div>
      </div>

      <div class="qn-pills">
        <span class="qn-pill">Works while inkwell is closed</span>
        <span class="qn-pill">Choose any vault folder</span>
        <span class="qn-pill">Draft persists if you close</span>
        <span class="qn-pill">Markdown supported</span>
      </div>
    </div>
  </section>

